# --- Zeabur / hosting ---------------------------------------------------------
# VITE_* variables are embedded in the client bundle at build time — they are
# not secret from end users. Restrict usage of your Google Maps key with HTTP
# referrer restrictions in Google Cloud Console.
# Store values in Zeabur Environment Variables per service (client vs server).
# Optional future pattern: proxy map requests through your backend so keys stay
# server-only.
# OpenStreetMap tiles used as a fallback need no API key; follow the OSM tile
# usage policy (https://operations.osmfoundation.org/policies/tiles/).

# Google Maps (direct) — used when VITE_FRONTEND_FORGE_API_KEY is unset
VITE_GOOGLE_MAPS_API_KEY=

# Frontend Forge proxy (takes precedence over direct Google key when set)
VITE_FRONTEND_FORGE_API_KEY=
# Optional override for the Forge base URL
# VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# Optional: fetch leads as JSON (array of Lead) instead of public/route_addresses.csv
# VITE_LEADS_DATA_URL=

# --- Zeabur deploy -----------------------------------------------------------
# 1. New Project → deploy from GitHub (this repo).
# 2. Zeabur detects Node + pnpm via packageManager in package.json.
# 3. In the service → Variables: add the same VITE_* keys as above. They must be
#    present at BUILD time (Zeabur usually passes env into both build and runtime).
# 4. Build: pnpm run build | Start: node dist/index.js (see zbpack.json).
# 5. Optional: use the Dockerfile in the repo root for a container build instead.
